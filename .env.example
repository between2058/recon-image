# =============================================================================
# ReconViaGen — Machine-specific configuration
#
# Usage:
#   cp .env.example .env
#   # Edit .env with paths for THIS machine, then:
#   docker compose up -d
#
# .env is gitignored — never commit it.
# =============================================================================

# Absolute path on the HOST where HuggingFace model cache lives.
# Container will mount it at /app/hf_cache (fixed, no need to change).
#
# Examples:
#   HF_CACHE_PATH=/pegaai/model_team/huggingface_cache   # prod server
#   HF_CACHE_PATH=/data/hf_cache                         # dev workstation
#   HF_CACHE_PATH=/mnt/nas/huggingface                   # NAS mount
HF_CACHE_PATH=/pegaai/model_team/huggingface_cache

# GPU device index to use (0-based). Run `nvidia-smi` to list available GPUs.
#   0 = first GPU, 1 = second GPU, etc.
GPU_ID=0

# (Optional) Hugging Face access token — required only for gated models.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
